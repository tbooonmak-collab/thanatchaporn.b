        "        else:\n",
        "            print(f\"{self.name} ไม่ได้ลงวิชา {course_name} อยู่\")\n",
        "\n",
        "    def show_courses(self):                         # method แสดงรายวิชาทั้งหมด\n",
        "        print(f\"วิชาที่ {self.name} ลงทะเบียน: {self.courses}\")\n",
