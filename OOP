        "class BankAccount:\n",
        "    def __init__(self, owner, balance=0):\n",
        "        self.owner = owner\n",
        "        self.balance = balance\n",
        "\n",
        "    def deposit(self, amount):\n",
        "        self.balance += amount\n",
        "        print(f'ฝากเงินเข้าจำนวน: {amount}')\n",
        "\n",
        "    def withdraw(self, amount):\n",
        "        if self.balance < amount:\n",
        "            print(\"จำนวนเงินไม่พอ\")\n",
        "        else:\n",
        "            self.balance -= amount\n",
        "            print(f\"ถอนเงินออกจำนวน: {amount} บาท ยอดเงินคงเหลือ: {self.balance} บาท \")\n",
        "\n",
        "    def show_balance(self):\n",
        "        print(f\"ยอดเงินคงเหลือ: {self.balance} บาท\")\n",
        "my_account = BankAccount(\"jazz\", 1000)\n",
